// Prisma schema for Weekly Report Generator & Team Dashboard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  MANAGER
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  reports            Report[]
  projectAssignments ProjectAssignment[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  reports     Report[]
  assignments ProjectAssignment[]
}

model ProjectAssignment {
  id        String  @id @default(uuid())
  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// One report row = one team member's log for a given week (optionally scoped to a project)
model Report {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  weekStart DateTime // Monday of the reporting week
  weekEnd   DateTime // Sunday of the reporting week

  tasksCompleted String  @db.Text
  tasksPlanned   String  @db.Text
  blockers       String? @db.Text
  hoursWorked    Float?
  notes          String? @db.Text

  status      ReportStatus @default(DRAFT)
  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart, projectId])
  @@index([weekStart])
  @@index([userId])
}
